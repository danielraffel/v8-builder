+class ExternalizedOneByteStringResource final
+    : public v8::String::ExternalOneByteStringResource {
+ public:
+  explicit ExternalizedOneByteStringResource(Tagged<String> source)
+      : length_(source->length()),
+        storage_(std::make_unique_for_overwrite<char[]>(length_)) {
+    String::WriteToFlat(source, reinterpret_cast<uint8_t*>(storage_.get()), 0,
+                        static_cast<uint32_t>(length_));
+  }
+
+  ~ExternalizedOneByteStringResource() override;
+
+  const char* data() const override { return storage_.get(); }
+  size_t length() const override { return length_; }
+
+ private:
+  const size_t length_;
+  const std::unique_ptr<char[]> storage_;
+};
+
+ExternalizedOneByteStringResource::~ExternalizedOneByteStringResource() =
+    default;
+
+class ExternalizedTwoByteStringResource final
+    : public v8::String::ExternalStringResource {
+ public:
+  explicit ExternalizedTwoByteStringResource(Tagged<String> source)
+      : length_(source->length()),
+        storage_(std::make_unique_for_overwrite<base::uc16[]>(length_)) {
+    String::WriteToFlat(source, storage_.get(), 0,
+                        static_cast<uint32_t>(length_));
+  }
+
+  ~ExternalizedTwoByteStringResource() override;
+
+  const uint16_t* data() const override { return storage_.get(); }
+  size_t length() const override { return length_; }
+
+ private:
+  const size_t length_;
+  const std::unique_ptr<base::uc16[]> storage_;
+};
+
+ExternalizedTwoByteStringResource::~ExternalizedTwoByteStringResource() =
+    default;
